{
  "name": "@affectively/aeon-flags",
  "version": "5.0.0",
  "description": "UCAN-powered Feature Flags with optional Edge Side Inference (ESI) cache and Tier gating. A lightweight alternative to CloudBees and LaunchDarkly.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./esi": {
      "import": "./dist/esi.js",
      "types": "./dist/esi.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "test": "bun test --coverage"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@affectively/aeon-flux": "^1.9.0"
  },
  "peerDependenciesMeta": {
    "@affectively/aeon-flux": {
      "optional": true
    }
  },
  "license": "MIT",
  "author": "Taylor William Buley (https://buley.fyi)"
}
